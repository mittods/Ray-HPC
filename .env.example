# ──────────────────────────────────────────────────────────────────────────────
# Di-Judge Ray Experiment – Environment Template
# Copy this file to .env and adjust as needed.
# ──────────────────────────────────────────────────────────────────────────────

# ─── Database ─────────────────────────────────────────────────────────────────
# PostgreSQL connection string for the experiment DB.
# Default port is 5433 to avoid conflict with the production DB on 5432.
EXP_DATABASE_URL=postgresql+asyncpg://dijudge:dijudge@exp-postgres:5432/dijudge_exp

# ─── Redis ────────────────────────────────────────────────────────────────────
# Redis URL used as Celery broker.  Not used by the Ray implementation.
EXP_REDIS_URL=redis://exp-redis:6379/0

# ─── Execution mode ───────────────────────────────────────────────────────────
# simulated: time.sleep simulates compile/run latency (no Docker needed)
# docker:    uses the real dijudge-sandbox image for actual code execution
EXECUTION_MODE=simulated

# ─── Simulated execution latencies ───────────────────────────────────────────
# Adjust these to match the expected latency profile of the target workload.
# All values in milliseconds.
COMPILE_MIN_MS=500
COMPILE_MAX_MS=2000
JUDGE_MIN_MS=100
JUDGE_MAX_MS=500

# ─── Workload configuration ───────────────────────────────────────────────────
# Number of test cases per synthetic problem.
TESTCASES_PER_PROBLEM=10
# Number of distinct synthetic problems in the pool.
PROBLEM_POOL_SIZE=5

# ─── Docker sandbox (only used when EXECUTION_MODE=docker) ───────────────────
SANDBOX_IMAGE=dijudge-sandbox:latest

# ─── Artifact storage ────────────────────────────────────────────────────────
# Must be a shared volume accessible by all worker containers.
ARTIFACT_ROOT=/artifacts

# ─── Ray cluster ─────────────────────────────────────────────────────────────
# Leave empty for local (single-node) mode; set to "auto" for cluster mode.
RAY_ADDRESS=
# Number of CPU slots to give Ray. 0 = auto-detect.
RAY_NUM_CPUS=0

# ─── Results ──────────────────────────────────────────────────────────────────
RESULTS_DIR=/results
